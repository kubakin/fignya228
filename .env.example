# =========================
# Required baseline values
# =========================

# Start page and input to focus/type into.
TARGET_URL=https://www.youtube.com
INPUT_SELECTOR=input[name="search_query"]

# Stage1 search query text (used in STAGE=stage1 and STAGE=both).
TEXT=How to kill boss calamitas terraria master mode


# =========================
# Stage selection
# =========================

# Allowed: stage1 | stage2 | both
STAGE=both

# Chance to skip stage1 when STAGE=both (0..1).
STAGE1_SKIP_PROB=0


# =========================
# Browser mode / profile
# =========================

# Headed-only mode: worker expects visible browser window for nut.js actions.

# Connect to already running Chrome/Edge via CDP:
# Example: http://127.0.0.1:9222
PLAYWRIGHT_CDP_URL=

# Alternative persistent profile mode (when not using CDP):
# PLAYWRIGHT_USER_DATA_DIR=C:\path\to\profile
PLAYWRIGHT_USER_DATA_DIR=
# Optional browser channel: chrome | msedge | chromium
PLAYWRIGHT_BROWSER_CHANNEL=chrome

# For packaged exe only: skip Playwright browser install on startup.
SKIP_PLAYWRIGHT_BROWSER_INSTALL=false


# =========================
# Mouse behavior
# =========================

# Base system mouse speed (px/s-like nut.js value).
MOUSE_SPEED=320

# Extra scaling for smooth move speed.
MOUSE_SMOOTH_SPEED_MULTIPLIER=0.72

# Optional click offsets for monitor/browser chrome calibration.
MOUSE_OFFSET_X=0
MOUSE_OFFSET_Y=0

# Safe top area in viewport to avoid header overlays.
CLICK_VIEWPORT_TOP_SAFE_PX=88

# Ghost-cursor-like overshoot tuning.
MOUSE_OVERSHOOT_THRESHOLD=500
MOUSE_OVERSHOOT_RADIUS=120
MOUSE_OVERSHOOT_SPREAD=10

# Stage2-only extra slow down multiplier for mouse.
STAGE2_MOUSE_SPEED_MULTIPLIER=0.55


# =========================
# Keyboard typing behavior
# =========================

# Typo ratio config:
# - TYPO_MAX_PERCENT: 5 means up to ~5% typo positions
# - TYPO_RATIO: alternative form in range 0..1
TYPO_MAX_PERCENT=5
# TYPO_RATIO=0.05

# Delay multiplier for typing pauses.
TYPING_DELAY_MULTIPLIER=1


# =========================
# Scrolling behavior (stage1)
# =========================

SCROLL_CYCLES_MIN=1
SCROLL_CYCLES_MAX=20


# =========================
# YouTube suggestion behavior
# =========================

# Optional override for YouTube suggestion option selector.
YT_SUGGESTION_OPTION_SELECTOR=


# =========================
# Stage1 video click + partial watch
# =========================

# Optional selector for video title link after search results scroll.
VIDEO_TITLE_SELECTOR=a#video-title

# Target partial-watch ratio (random in [min, max]).
VIDEO_END_MIN_RATIO=0.1
VIDEO_END_MAX_RATIO=0.2

# Optional absolute watch-time limits for stage1 (seconds).
# If both set -> random time in [min,max].
# If only min set -> target is at least min.
# If only max set -> target is at most max.
VIDEO_WATCH_MIN_SEC=
VIDEO_WATCH_MAX_SEC=

# 0 means no timeout for wait-until-target-ratio.
VIDEO_NEAR_END_TIMEOUT_MS=0

# Progress log interval while watching.
VIDEO_PROGRESS_INTERVAL_MS=2500

# Recovery when YouTube shows "Something went wrong".
VIDEO_WATCH_ERROR_RETRY_MAX=2
VIDEO_WATCH_ERROR_COOLDOWN_MS=0


# =========================
# Stage2: channel + videos flow
# =========================

# Stage2 typed text (always full typing + Enter).
CHANNEL_TARGET_NAME=Some channel name

# Target channel href to find while scrolling results.
CHANNEL_TARGET_HREF=https://www.youtube.com/@channel
CHANNEL_FIND_TIMEOUT_MS_MIN=10000
CHANNEL_FIND_TIMEOUT_MS_MAX=20000

# On channel page -> Videos tab -> target video href.
VIDEO_TARGET_HREF=https://www.youtube.com/watch?v=XXXXXXXXXXX
# Optional: target video title (used by stage2 variant3 search query).
VIDEO_TARGET_NAME=Video title to search
# Optional VK group URL for stage2 vkStrategy.
VK_GROUP_URL=https://vk.com/some_group
# Optional landing page URL for stage2 landingStrategy.
LANDING_URL=https://example.com
VIDEO_FIND_TIMEOUT_MS_MIN=15000
VIDEO_FIND_TIMEOUT_MS_MAX=20000

# Stage2 strategy probabilities (weights; any non-negative numbers).
# channelSearchStrategy: YouTube search -> channel -> Videos tab -> video by href
# webChannelSearchStrategy: web search by channel name -> channel -> Videos tab
# webVideoSearchStrategy: web search by video name -> open video directly
# directLinkStrategy: direct navigation by URL
# vkStrategy: open VK group, scroll/hover, patch visible link to YouTube URL and click
# landingStrategy: open landing URL, move/scroll, patch visible absolute link to YouTube URL and click
STAGE2_STRATEGY_CHANNEL_SEARCH_PROB=0.55
STAGE2_STRATEGY_WEB_CHANNEL_PROB=0.30
STAGE2_STRATEGY_WEB_VIDEO_PROB=0.15
STAGE2_STRATEGY_DIRECT_LINK_PROB=0.10
STAGE2_STRATEGY_VK_PROB=0.10
STAGE2_STRATEGY_LANDING_PROB=0.10

# Max runtime for chosen stage2 strategy before forced fallback to directLinkStrategy.
STAGE2_STRATEGY_TIMEOUT_MS=120000
# Legacy aliases still supported:
# STAGE2_VARIANT1_PROB / STAGE2_VARIANT2_PROB / STAGE2_VARIANT3_PROB
# STAGE2_VARIANT_TIMEOUT_MS

# Stage2 success: random target watch ratio in [min, max] (0..1). Report "completed" only after this.
# Default 0.8–1.0 = 80–100% of the video.
# If omitted, fill uses VIDEO_END_MIN_RATIO / VIDEO_END_MAX_RATIO (same as stage1), e.g. from task config.
# Aliases: STAGE2_VIDEO_END_MIN / STAGE2_VIDEO_END_MAX (same as ..._MIN_RATIO / ..._MAX_RATIO).
STAGE2_VIDEO_END_MIN_RATIO=0.8
STAGE2_VIDEO_END_MAX_RATIO=1.0


# =========================
# Misc timing
# =========================

# Delay after initial page load before first action.
POST_LOAD_MS_MIN=1000
POST_LOAD_MS_MAX=3000

# Optional legacy aliases accepted by code:
# URL (alias of TARGET_URL)
# SELECTOR (alias of INPUT_SELECTOR)
